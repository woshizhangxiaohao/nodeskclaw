# ── NoDeskClaw 环境变量 ──

# App
DEBUG=true

# Database（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/nodeskclaw

# JWT — 生产环境务必替换
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# KubeConfig 加密密钥（32 字节 base64）
ENCRYPTION_KEY=change-me-32-bytes-base64-key__=

# 飞书 SSO（Admin 应用）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://localhost:5173/login/callback/feishu

# 飞书 SSO（Portal 应用，可选）
FEISHU_APP_ID_PORTAL=
FEISHU_APP_SECRET_PORTAL=

# 云平台
VKE_SUBNET_ID=

# GeneHub
GENEHUB_REGISTRY_URL=
GENEHUB_WEB_URL=

# 镜像仓库配置已迁移到数据库（Settings 页面管理），不再通过 .env 配置

# CORS
CORS_ORIGINS=["http://localhost:5173"]
